# Copy this file to `.env` and edit the values for your server.

EXPORTER_PROFILE=release
CARGO_BUILD_JOBS=1
TMPDIR=/tmp
TMP=/tmp
TEMP=/tmp

RUN_ROOT="$SCRIPT_DIR/out/base_eth_usdc_case"
RPC_URL=http://127.0.0.1:8545
INDEXER_URL=http://127.0.0.1:8080
SELECTED_POOLS_FILE="$SCRIPT_DIR/config/default_selected_pools.base_eth_usdc.txt"
STABLE_TOKENS_FILE="$SCRIPT_DIR/config/default_stable_tokens.base_eth_usdc.json"

FROM_BLOCK=27800000
TO_BLOCK=27801000
SHARD_SIZE_BLOCKS=200
VALIDATION_STRIDE_TARGETS=20

VERIFY_AFTER_EXPORT=1
