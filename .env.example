# Copy this file to `.env` and edit the values for your server.

EXPORTER_PROFILE=release
CARGO_BUILD_JOBS=1
TMPDIR=/tmp
TMP=/tmp
TEMP=/tmp

RUN_ROOT=/srv/base-backtest-exporter/out/base_replay_run
RPC_URL=http://127.0.0.1:8545
INDEXER_URL=http://127.0.0.1:8080
SELECTED_POOLS_FILE=/srv/base-backtest-exporter/config/selected_pools.txt
STABLE_TOKENS_FILE=/srv/base-backtest-exporter/config/stable_tokens.json

FROM_BLOCK=27800000
TO_BLOCK=27801000
SHARD_SIZE_BLOCKS=200
VALIDATION_STRIDE_TARGETS=20

VERIFY_AFTER_EXPORT=1
